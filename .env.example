# Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (type: Web application)
# 2. Add authorized JavaScript origin: http://localhost:3000
# 3. Add authorized redirect URI: http://localhost:3000/auth/callback
# 4. Enable the Gmail API: https://console.cloud.google.com/apis/library/gmail.googleapis.com
# 5. Copy the Client ID and Client Secret from the OAuth 2.0 Client ID details page
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Server-only secret used to exchange authorization codes for tokens (never expose to the browser)
GOOGLE_CLIENT_SECRET=scret_key
